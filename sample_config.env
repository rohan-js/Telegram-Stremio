# Startup Config
API_ID=""
API_HASH=""
BOT_TOKEN=""
HELPER_BOT_TOKEN=""
OWNER_ID=""
REPLACE_MODE="true"
HIDE_CATALOG="false"
PARALLEL="4"
PRE_FETCH="3"

# SMART STREAM ROUTING (safe defaults)
SMART_ROUTING_ENABLED="true"
SMART_ROUTING_PROBE_ENABLED="true"
SMART_ROUTING_PROBE_CLIENTS="3"
SMART_ROUTING_PROBE_BYTES="262144"
SMART_ROUTING_PROBE_TIMEOUT_SEC="4"
SMART_ROUTING_FIRST_CHUNK_TIMEOUT_SEC="4"
SMART_ROUTING_CHUNK_TIMEOUT_SEC="15"

# DISK CACHE (optional, safe-by-default)
# - Enable DISK_CACHE_* to pre-download media to local disk (LRU-bounded).
# - If NGINX_ACCEL_REDIRECT_ENABLED is true, /dl will return X-Accel-Redirect
#   so nginx serves bytes directly while auth stays in-app.
DISK_CACHE_ENABLED="false"
DISK_CACHE_PRECACHE_ON_INGEST="false"
DISK_CACHE_DIR="cache"
# Set either MAX_GB or MAX_BYTES (required when cache enabled)
DISK_CACHE_MAX_GB="0"
DISK_CACHE_MAX_BYTES="0"
DISK_CACHE_CONCURRENCY="1"

# NGINX INTERNAL REDIRECT (optional)
NGINX_ACCEL_REDIRECT_ENABLED="false"
NGINX_ACCEL_REDIRECT_LOCATION="/_cache/"

# STREAMING SLO WARNING LOGS (optional)
STREAM_SLO_TTFB_WARN_SEC="3"
STREAM_SLO_TIMEOUT_WARN_COUNT="2"
STREAM_SLO_BUFFERING_WARN_RATE="0.05"

# STORAGE
AUTH_CHANNEL=""
DATABASE=""

# API
TMDB_API=""

# SERVER
BASE_URL=""
PORT="8000"
DEFAULT_ADDON_TOKEN=""

# UPDATE REPO
UPSTREAM_REPO=""
UPSTREAM_BRANCH="master"

# ADMIN PANNEL
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# SUBSCRIPTION CONFIG
SUBSCRIPTION=False                      #without ""
SUBSCRIPTION_GROUP_ID=                  #without ""
APPROVER_IDS= #without ""
SUBSCRIPTION_URL=""                     #telegram bot url like https://t.me/username

# PROXY CONFIG
Proxy=True
ProxyType=HTTPS
HTTP_Proxy_URL=""                       #example https://PROXYURL/?url=
SHOW_ProxyAndNonProxyBoth=True          #this will show both link proxy and non proxy both

# MULTI TOKEN CONFIG
MULTI_TOKEN1=""

# Startup Config
API_ID=""
API_HASH=""
BOT_TOKEN=""
HELPER_BOT_TOKEN=""
USER_SESSION_STRING=""                 #optional userbot session for Global Search; keep secret/env-only
TELEGRAM_PROXY_ENABLED="false"          #true routes only PyroFork Telegram clients through proxy
TELEGRAM_PROXY_SCHEME="socks5"          #socks4, socks5, or http
TELEGRAM_PROXY_HOST=""                  #example 127.0.0.1 for local WARP proxy mode
TELEGRAM_PROXY_PORT=""                  #example 40000
TELEGRAM_PROXY_USERNAME=""
TELEGRAM_PROXY_PASSWORD=""
TELEGRAM_CLIENT_START_TIMEOUT_SEC="45"
WARP_CONTROL_COMMAND=""                 #optional host-side helper command for dashboard WARP toggle
WARP_CONTROL_URL=""                     #example http://host.docker.internal:8765
WARP_CONTROL_SECRET=""                  #shared secret for deploy/warp_control_server.py
OWNER_ID=""
REPLACE_MODE="true"
HIDE_CATALOG="false"
PARALLEL="4"
PRE_FETCH="3"

# TELEGRAM CDN STREAMING
# Some Telegram files redirect to CDN storage. This feature follows those redirects inside
# the Telegram stream fetcher only; it will not affect torrent, IPTV, qBittorrent, or Nginx.
TELEGRAM_CDN_ENABLED="false"
TELEGRAM_CDN_VERIFY_HASHES="true"
TELEGRAM_CDN_MAX_REUPLOAD_ATTEMPTS="2"
TELEGRAM_CDN_DEBUG_LOGS="false"

# SMART STREAM ROUTING (safe defaults)
SMART_ROUTING_ENABLED="true"
SMART_ROUTING_PROBE_ENABLED="true"
SMART_ROUTING_PROBE_CLIENTS="3"
SMART_ROUTING_PROBE_BYTES="262144"
SMART_ROUTING_PROBE_TIMEOUT_SEC="4"
SMART_ROUTING_FIRST_CHUNK_TIMEOUT_SEC="4"
SMART_ROUTING_CHUNK_TIMEOUT_SEC="15"
SMART_ROUTING_COOLDOWN_FAILURES="2"
SMART_ROUTING_COOLDOWN_SEC="180"

# ADAPTIVE STREAM PREFETCH
# Never raises PARALLEL/PRE_FETCH; only reduces them when the VPS is busy or low on memory.
ADAPTIVE_PREFETCH_ENABLED="true"
ADAPTIVE_PREFETCH_LOW_MEM_MB="150"
ADAPTIVE_PREFETCH_MULTI_STREAM_THRESHOLD="2"
ADAPTIVE_PREFETCH_SMALL_REQUEST_BYTES="16777216"
ADAPTIVE_PREFETCH_SMALL_FILE_BYTES="67108864"

# IPTV LIVE TV (iptv-org)
# Global by default. Leave IPTV_COUNTRY_CODES blank to index all playable public channels.
IPTV_ENABLED="true"
IPTV_COUNTRY_CODES=""
IPTV_PAGE_SIZE="50"
IPTV_AUTO_SYNC="true"
IPTV_SYNC_INTERVAL_MINUTES="360"
IPTV_SYNC_START_DELAY_SECONDS="30"
IPTV_REQUEST_TIMEOUT_SEC="45"
IPTV_PROXY_TIMEOUT_SEC="30"
IPTV_PROXY_FALLBACK_ENABLED="true"
IPTV_PROXY_SECRET=""
IPTV_API_BASE_URL="https://iptv-org.github.io/api"

# DISK CACHE (optional, safe-by-default)
# - Enable DISK_CACHE_* to pre-download media to local disk (LRU-bounded).
# - If NGINX_ACCEL_REDIRECT_ENABLED is true, /dl will return X-Accel-Redirect
#   so nginx serves bytes directly while auth stays in-app.
DISK_CACHE_ENABLED="false"
DISK_CACHE_PRECACHE_ON_INGEST="false"
DISK_CACHE_DIR="cache"
# Set either MAX_GB or MAX_BYTES (required when cache enabled)
DISK_CACHE_MAX_GB="0"
DISK_CACHE_MAX_BYTES="0"
DISK_CACHE_CONCURRENCY="1"

# NGINX INTERNAL REDIRECT (optional)
NGINX_ACCEL_REDIRECT_ENABLED="false"
NGINX_ACCEL_REDIRECT_LOCATION="/_cache/"

# STREAMING SLO WARNING LOGS (optional)
STREAM_SLO_TTFB_WARN_SEC="3"
STREAM_SLO_TIMEOUT_WARN_COUNT="2"
STREAM_SLO_BUFFERING_WARN_RATE="0.05"

# TORRENT STATS (tracker scrape estimates, no DHT)
TORRENT_STATS_ENABLED="true"
TORRENT_STATS_TTL_SEC="21600"
TORRENT_STATS_FAILURE_TTL_SEC="3600"
TORRENT_STATS_MAX_TRACKERS="5"
TORRENT_STATS_TIMEOUT_SEC="2.5"
TORRENT_STATS_CONCURRENCY="3"

# TORRENT DOWNLOADS (manual download-to-VPS stream cache)
TORRENT_DOWNLOADS_ENABLED="true"
TORRENT_DOWNLOAD_ROOT="/downloads/completed"
TORRENT_DOWNLOAD_MIN_FREE_GB="10"
TORRENT_DOWNLOAD_CONCURRENCY="1"
TORRENT_DOWNLOAD_POLL_SEC="15"
TORRENT_DOWNLOAD_PROGRESS_EDIT_SEC="60"
TORRENT_DOWNLOAD_STALL_TIMEOUT_SEC="3600"
TORRENT_DOWNLOAD_MAX_RUNTIME_SEC="172800"
QBITTORRENT_BASE_URL="http://qbittorrent:8080"
QBITTORRENT_USERNAME=""
QBITTORRENT_PASSWORD=""
QBITTORRENT_SAVE_PATH="/downloads/completed"
QBITTORRENT_TEMP_PATH="/downloads/incomplete"
NGINX_DOWNLOAD_ACCEL_REDIRECT_ENABLED="true"
NGINX_DOWNLOAD_ACCEL_REDIRECT_LOCATION="/_downloads/"

# DASHBOARD HTTP EGRESS (nginx bytes actually sent to clients)
NGINX_EGRESS_ENABLED="true"
NGINX_EGRESS_LOG_PATHS="/host/var/log/nginx/access.log,/host/var/log/nginx/access.log.1"
NGINX_EGRESS_STREAM_PREFIXES="/dl/,/downloaded/,/iptv/"
NGINX_EGRESS_CACHE_SEC="30"
VPS_OUTBOUND_ENABLED="true"
VPS_OUTBOUND_INTERFACE="ens3"
VPS_OUTBOUND_TX_BYTES_PATH="/host/ens3_tx_bytes"
VPS_OUTBOUND_NET_DEV_PATH="/host/proc/net/dev"
VPS_OUTBOUND_MONTHLY_LIMIT_BYTES="10995116277760"

# STORAGE
AUTH_CHANNEL=""
MANUAL_CHANNELS=""                     #optional channels used only while a Manual Upload Session is active
DATABASE=""
ANIME_CHANNELS=""                       #optional comma-separated channel IDs that should try anime metadata first
GLOBAL_SEARCH="false"
GLOBAL_SEARCH_CHANNELS=""
CONTENT_REQUESTS_ENABLED="false"
CONTENT_REQUESTS_BETA_ONLY="true"
ANNOUNCE_NEW_CONTENT="false"
ANNOUNCEMENT_CHANNEL=""

# API
TMDB_API=""

# LLM METADATA RERANKER (optional, fastest path skips clean matches)
METADATA_RERANKER_ENABLED="false"
GEMINI_MATCHER_ENABLED="false"
METADATA_RERANKER_PROVIDER="auto"
GROQ_API_KEY=""
GROQ_MATCHER_MODEL="llama-3.1-8b-instant"
GROQ_MATCHER_FALLBACK_MODEL="llama-3.3-70b-versatile"
GEMINI_API_KEY=""
GEMINI_MATCHER_MODEL="gemini-3.1-flash-lite"
GEMINI_MATCHER_FALLBACK_MODEL="gemini-2.5-flash-lite"
GEMINI_MATCHER_TIMEOUT_SECONDS="0.9"
GEMINI_MATCHER_MAX_CANDIDATES="4"
GEMINI_MATCHER_MIN_TOP_MARGIN="8"
GEMINI_MATCHER_CACHE_TTL_SECONDS="86400"
GEMINI_MATCHER_CACHE_MAX="2000"

# SERVER
BASE_URL=""
PORT="8000"
DEFAULT_ADDON_TOKEN=""
NUVIO_WATCH_ENABLED="true"            #show callback-gated Watch in Nuvio buttons for matched media
SESSION_SECRET=""                      #optional stable admin-session secret; leave blank to use app fallback

# PRIVATE BETA / ACCESS HARDENING
PUBLIC_BETA_ENABLED="false"            #true enables invite/terms beta controls
BETA_INVITE_ONLY="true"
BETA_ALLOWED_USER_IDS=""               #comma-separated Telegram user IDs allowed to join beta
BETA_EXEMPT_USER_IDS=""                #comma-separated user IDs that bypass beta/subscription limits
BETA_EXEMPT_TOKEN_NAMES="autotest-temp" #existing free/unaffected token names
BETA_EXEMPT_TOKENS=""                  #comma-separated exact token strings, keep empty in public configs
BETA_WAITLIST_MESSAGE="This private beta is invite-only right now. Please contact the admin for access."
REQUIRE_TERMS_ACCEPTANCE="true"
TERMS_VERSION="2026-07-07"
DEFAULT_TOKEN_DAILY_LIMIT_GB="25"
DEFAULT_TOKEN_MONTHLY_LIMIT_GB="300"
DEFAULT_TOKEN_MAX_ACTIVE_STREAMS="2"
MAX_ACTIVE_STREAMS_GLOBAL="4"
STREAM_LOG_RETENTION_DAYS="30"
BILLING_LOG_RETENTION_DAYS="180"
OWNER_ALERTS_ENABLED="true"
BACKUP_ENABLED="true"
BACKUP_DIR="backups/production"
BACKUP_INTERVAL_HOURS="24"

# UPDATE REPO
UPSTREAM_REPO=""
UPSTREAM_BRANCH="master"

# ADMIN PANNEL
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# SUBSCRIPTION CONFIG
SUBSCRIPTION=False                      #without ""
SUBSCRIPTION_GROUP_ID=                  #without ""
APPROVER_IDS= #without ""
SUBSCRIPTION_URL=""                     #telegram bot url like https://t.me/username

# PROXY CONFIG
Proxy=True
ProxyType=HTTPS
HTTP_Proxy_URL=""                       #example https://PROXYURL/?url=
SHOW_ProxyAndNonProxyBoth=True          #this will show both link proxy and non proxy both

# MULTI TOKEN CONFIG
MULTI_TOKEN1=""
